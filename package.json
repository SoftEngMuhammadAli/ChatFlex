{
  "name": "chatflex-mern",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "server",
    "client",
    "widget"
  ],
  "scripts": {
    "dev": "concurrently \"npm --prefix server run dev\" \"npm --prefix client run dev\" \"npm --prefix widget run dev\"",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "dev:widget": "npm --prefix widget run dev",
    "build:widget": "npm --prefix widget run build",
    "build:client": "npm --prefix client run build",
    "build": "npm run build:widget && npm run build:client"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
