# =========================
# Client Environment Variables
# =========================

# API URL for backend requests (required)
VITE_API_URL=http://localhost:5000/api/v1

# =========================
# OAuth Providers
# =========================

# Google OAuth Client ID (required for Google sign-in)
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# GitHub OAuth Client ID (required for GitHub sign-in)
VITE_GITHUB_CLIENT_ID=your_github_client_id

# GitHub OAuth Redirect URI (optional, defaults to current origin + /login)
VITE_GITHUB_REDIRECT_URI=http://localhost:5173/login
