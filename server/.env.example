NODE_ENV=development
PORT=5000

# Client / CORS
CLIENT_URL=http://localhost:5173
# Comma-separated extra allowed origins (optional)
ALLOWED_ORIGINS=

# Database
MONGO_URI=mongodb://127.0.0.1:27017/chatflex

# Redis (required for queue-backed notifications/integrations and scalable rate limiting)
REDIS_URL=redis://127.0.0.1:6379

# Auth
JWT_SECRET=change_me
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Email (optional; required for verification + notification emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=support@chatflex.com

# AI (Groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Delivery modes (optional)
# - When unset: queue-backed delivery is used when REDIS_URL is configured; falls back to inline if not.
# - Set to "inline" to force synchronous delivery.
NOTIFICATION_DELIVERY_MODE=
INTEGRATION_DELIVERY_MODE=

# Workflow scheduler
WORKFLOW_INTERVAL_MS=60000

