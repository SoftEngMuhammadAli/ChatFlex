<h2
  style="
    margin: 0 0 10px;
    color: #0f172a;
    font-size: 22px;
    line-height: 1.3;
    font-weight: 700;
  "
>
  Verify Your ChatFlex Account
</h2>
<p style="margin: 0 0 14px; color: #334155; font-size: 14px; line-height: 1.7">
  Hi <strong><%= name %></strong>,
</p>
<p style="margin: 0 0 18px; color: #334155; font-size: 14px; line-height: 1.7">
  Thanks for signing up. Please verify your email address to activate your
  account and continue using ChatFlex.
</p>
<table
  role="presentation"
  cellpadding="0"
  cellspacing="0"
  style="margin: 0 0 18px"
>
  <tr>
    <td align="center" style="border-radius: 10px; background: #0f766e">
      <a
        href="<%= verificationUrl %>"
        style="
          display: inline-block;
          padding: 12px 18px;
          color: #ffffff;
          font-size: 14px;
          font-weight: 700;
          text-decoration: none;
        "
      >
        Verify Email
      </a>
    </td>
  </tr>
</table>
<p style="margin: 0 0 8px; color: #64748b; font-size: 12px; line-height: 1.6">
  This link expires in 24 hours.
</p>
<p style="margin: 0; color: #64748b; font-size: 12px; line-height: 1.6">
  If the button doesn't work, use this link:<br />
  <a
    href="<%= verificationUrl %>"
    style="color: #0f766e; text-decoration: underline; word-break: break-all"
    ><%= verificationUrl %></a
  >
</p>
